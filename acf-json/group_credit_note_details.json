{
    "key": "group_credit_note_details",
    "title": "Detaily dobropisu",
    "fields": [
        {
            "key": "field_credit_note_company",
            "label": "Fakturující firma",
            "name": "credit_note_company",
            "type": "post_object",
            "post_type": [
                "company"
            ],
            "required": 1
        },
        {
            "key": "field_credit_note_invoice",
            "label": "Faktura ke které se dobropis váže",
            "name": "credit_note_invoice",
            "type": "post_object",
            "post_type": [
                "invoice"
            ],
            "required": 1
        },
        {
            "key": "field_credit_note_reason",
            "label": "Důvod opravy",
            "name": "credit_note_reason",
            "type": "textarea",
