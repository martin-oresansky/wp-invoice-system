        },
        {
            "key": "field_payment_tab",
            "label": "Platební údaje",
            "type": "tab"
        },
        {
            "key": "field_credit_note_account_number",
            "label": "Číslo účtu",
            "name": "credit_note_account_number",
            "type": "text"
        },
        {
            "key": "field_credit_note_variable_symbol",
            "label": "Variabilní symbol",
            "name": "credit_note_variable_symbol",
            "type": "text"
        },
        {
            "key": "field_credit_note_items_tab",
            "label": "Položky dobropisu",
            "type": "tab"
        },
        {
            "key": "field_credit_note_items",
            "label": "Položky dobropisu",
            "name": "credit_note_items",
            "type": "repeater",
            "layout": "table",
            "button_label": "Přidat položku",
            "required": 1,
            "sub_fields": [
                {
                    "key": "field_credit_note_item_name",
                    "label": "Název",
                    "name": "name",
                    "type": "text"
                },
                {
                    "key": "field_credit_note_item_quantity",
                    "label": "Množství",
                    "name": "quantity",
                    "type": "number",
                    "default_value": 1
                },
                {
                    "key": "field_credit_note_item_price",
                    "label": "Cena/jedn.",
                    "name": "price",
                    "type": "number"
                },
                {
                    "key": "field_credit_note_item_vat_rate",
                    "label": "Sazba DPH",
                    "name": "vat_rate",
                    "type": "select",
                    "choices": {
                        "21": "21%",
                        "12": "12%",
                        "0": "0%"
                    },
                    "default_value": "21",
                    "ui": 1
                }
            ]
        }
    ],
    "location": [
        [
            {
                "param": "post_type",
                "operator": "==",
                "value": "credit-note"
            }
        ]
    ]
