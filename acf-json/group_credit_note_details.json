        },
        {
            "key": "field_dates_tab",
            "label": "Datumy a nastavení",
            "type": "tab"
        },
        {
            "key": "field_credit_note_date_issue",
            "label": "Datum vystavení",
            "name": "credit_note_date_issue",
            "type": "date_picker",
