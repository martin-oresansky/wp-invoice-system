            "return_format": "j.n.Y",
            "required": 1
        },
        {
            "key": "field_credit_note_date_taxable",
            "label": "Datum uskutečnitelného zdanitelného plnění",
            "name": "credit_note_date_taxable",
            "type": "date_picker",
            "display_format": "j.n.Y",
            "return_format": "j.n.Y",
            "required": 1
        },
        {
            "key": "field_credit_note_date_due",
            "label": "Datum splatnosti",
            "name": "credit_note_date_due",
            "type": "date_picker",
            "display_format": "j.n.Y",
            "return_format": "j.n.Y",
            "required": 1
        },
        {
            "key": "field_credit_note_prices_include_vat",
            "label": "Ceny zadávat včetně DPH",
            "name": "credit_note_prices_include_vat",
            "type": "true_false",
            "ui": 1,
